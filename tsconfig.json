{
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "dist/",
    "rootDir": ".",
    "sourceMap": true,
    "target": "es2020",
    "types": ["node"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
  },
  "include": ["src/**/*.ts"],
}
